<!--  
<%=versionText%>  
-->

<div id="<%= modulePart %>-header">
</div>

<div class="search-container">
	<div id="<%= modulePart %>-pnl_search" class="search-parameters">
		<input id="<%= modulePart %>-txt_searchtext" fgta5-component="Textbox" placeholder="search" autocomplete="off"
			spellcheck="false" binding="searchtext" data-searchinput>
	</div>
	<button id="<%= modulePart %>-btn_gridload" class="action-button button-load">
		<span class="action-button-icon">
			<img src="public/icons/button-load.svg">
		</span>
		<span class="action-button-text">LOAD</span>
	</button>
</div>

<table id="<%= modulePart %>-tbl" fgta5-component="Gridview">
	<thead>
		<tr data-header key="<%= section.primaryKey %>">
			<% fields.forEach(field=> { %>
				<th data-name="<%= field.dataName %>" binding="<%= field.binding %>" <%- field.additionalAttributes %>>
					<%= field.label %>
				</th>
				<% }); %>
		</tr>
	</thead>
</table>

<div id="<%= modulePart %>-foot">
</div>

<div class="footer-buttons-container">
	<div></div>
	<div style="display: flex; column-gap: 5px; align-items: center;">
		<button id="<%=modulePart%>-btn_new" data-action="<%= moduleSection %>-new"
			data-sectionsource="<%=modulePart%>-section" class="action-button button-withtext button-new">
			<span class="action-button-icon">
				<img src="public/icons/button-new.svg">
			</span>
			<span class="action-button-text">New</span>		
		</button>
	</div>
	<div></div>
</div>